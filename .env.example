# ICT web UI — environment for docker compose.
# Copy to .env and fill in real values. `.env` is git-ignored.
#
# Only the JENKINS_* trio matters for the dispatch endpoint to work.
# Without them the backend still starts, serves the UI, and returns
# HTTP 503 on POST /api/v1/jenkins/dispatch — the frontend surfaces
# this as a clean "Jenkins dispatch is not configured" error.

# --- Jenkins farm (required for dispatches) ---
JENKINS_URL=https://cje-pg-prod01.devtools.intel.com/nex-cisv-devops02
JENKINS_USER=your-idsid
JENKINS_TOKEN=change-me
# Defaults to ict-farm/workers if unset — matches the code default.
JENKINS_WORKERS_PATH=ict-farm/workers

# --- Intel network proxy (only needed inside the corporate network) ---
# Uncomment on Intel-network hosts; leave commented on public networks.
# HTTP_PROXY=http://proxy-dmz.intel.com:912
# HTTPS_PROXY=http://proxy-dmz.intel.com:912
# NO_PROXY=localhost,127.0.0.1,.intel.com
